{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floralexicon.com/schemas/tier3.schema.json",
  "title": "FloraLexicon Tier 3 Country-Specific Entry",
  "description": "A Tier 3 file describes plants specific to a single country, with no cross-country naming obligation. A plant may appear in Tier 3 for multiple countries as independent entries; a plant may NOT appear in Tier 3 if it is in Tier 1 or Tier 2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "country",
    "tier",
    "plants"
  ],
  "properties": {
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code."
    },
    "tier": {
      "const": 3
    },
    "plants": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/PlantBlock"
      },
      "description": "Keys are plant_ids. Plant_id must NOT appear in any Tier 1 or Tier 2 file."
    },
    "file_label": {
      "type": "string",
      "description": "Optional editorial grouping label, e.g. 'endemic_patagonia' or 'andean_medicinals'. Purely organisational."
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "LanguageCode": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "Source": {
      "type": "string",
      "enum": [
        "pharmacopoeia",
        "pharmacopoeia_traditional",
        "regulatory",
        "ethnobotany",
        "commercial",
        "traditional",
        "linguistic"
      ]
    },
    "Confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "PlantBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names"
      ],
      "properties": {
        "names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/NameEntry"
          },
          "description": "Unlike Tier 1/2, Tier 3 names are a flat array (single country, no keying). First entry is implicit primary."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "NameEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "language",
        "confidence",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "$ref": "#/$defs/LanguageCode"
        },
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "citation": {
          "type": "string"
        },
        "transliteration": {
          "type": "string"
        },
        "transliteration_scheme": {
          "type": "string",
          "enum": [
            "ala_lc",
            "bgn_pcgn",
            "buckwalter",
            "din_31635",
            "gost",
            "hepburn",
            "iast",
            "iso_15919",
            "iso_843",
            "iso_9",
            "kunrei",
            "pinyin",
            "pinyin_toneless",
            "rr",
            "rtgs",
            "yale"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "_schema_version": "1.2",
  "_changelog": [
    "v1.1 (2026-04-23): added pharmacopoeia_traditional to Source enum; added transliteration_scheme enum field",
    "v1.2 (2026-04-23): added iso_843 (Greek) and rtgs (Thai) to transliteration_scheme enum; documented ala_lc covers Hebrew"
  ]
}