{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floralexicon.com/schemas/tier2.schema.json",
  "title": "FloraLexicon Tier 2 Regional Entry",
  "description": "A Tier 2 file describes plants significant within a specific region. Every plant listed MUST have names for every country in the region's roster. No plant may appear in Tier 1 and Tier 2 simultaneously.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "region_id",
    "tier",
    "countries",
    "plants"
  ],
  "properties": {
    "region_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Must match a region_id from canonical/regions.json."
    },
    "tier": {
      "const": 2
    },
    "countries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/CountryCode"
      },
      "description": "Country roster. Every plant in this file must have names for every country here."
    },
    "plants": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/PlantBlock"
      },
      "description": "Keys are plant_ids. Plant_id must NOT appear in any Tier 1 file."
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "CountryCode": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "LanguageCode": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "Source": {
      "type": "string",
      "enum": [
        "pharmacopoeia",
        "pharmacopoeia_traditional",
        "regulatory",
        "ethnobotany",
        "commercial",
        "traditional",
        "linguistic"
      ]
    },
    "Confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "PlantBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names"
      ],
      "properties": {
        "names": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/CountryCode"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/NameEntry"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "NameEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "language",
        "confidence",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "$ref": "#/$defs/LanguageCode"
        },
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "citation": {
          "type": "string"
        },
        "transliteration": {
          "type": "string"
        },
        "transliteration_scheme": {
          "type": "string",
          "enum": [
            "ala_lc",
            "bgn_pcgn",
            "buckwalter",
            "din_31635",
            "gost",
            "hepburn",
            "iast",
            "iso_15919",
            "iso_843",
            "iso_9",
            "kunrei",
            "pinyin",
            "pinyin_toneless",
            "rr",
            "rtgs",
            "yale"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "_schema_version": "1.2",
  "_changelog": [
    "v1.1 (2026-04-23): added pharmacopoeia_traditional to Source enum; added transliteration_scheme enum field",
    "v1.2 (2026-04-23): added iso_843 (Greek) and rtgs (Thai) to transliteration_scheme enum; documented ala_lc covers Hebrew"
  ]
}