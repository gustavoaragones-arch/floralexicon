    "uses": [
    {
    "plant_id": "baccharis_trimera",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used internally as a
   stomachic, liver tonic (infusion 1–2%), bitter tonic and
   febrifuge (infusion 10%). Also used regionally as antirheumatic,
   anthelmintic, for diabetes, gastroenteritis, anorexia, flu, and
   colds. Externally used for wound and ulcer treatment.",
    "evidence_level": "preliminary_science",
    "regions": ["UY", "AR"]
    },
    {
    "use": "Pharmacological data indicate hypoglycemic
   action in aqueous extracts, inhibition of Trypanosoma cruzi
   growth, activity against schistosomiasis vectors,
   hepatoprotective, antiulcer, and antibiotic activity.",
    "evidence_level": "preliminary_science",
    "regions": ["UY", "AR"]
    }
    ],
    "culinary": ["Bitter beverage ingredient in Argentina"],
    "aromatic": []
    }
    },
    {
    "plant_id": "conyza_bonariensis",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used internally: infusion 1%
   as hepatoprotector and antiulcer; infusion 3–4% as diuretic for
   genitourinary conditions and urethral washes; decoction 10% as
   depurative antirheumatic for uric acid elimination. Fresh leaf
   infusion 1% traditionally used for stomach ulcers.",
    "evidence_level": "traditional",
    "regions": ["UY", "AR"]
    },
    {
    "use": "Externally used as antiseptic and healing
   agent applied as fresh leaf poultice on wounds.",
    "evidence_level": "traditional",
    "regions": ["UY", "AR"]
    }
    ],
    "culinary": ["Refreshing beverage prepared with roots
   and linseed in Argentina"],
    "aromatic": []
    }
    },
    {
    "plant_id": "matricaria_recutita",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used internally for
   gastrointestinal disturbances, antispasmodic, sedative,
   digestive. Hepatic, diuretic, emollient, carminative, and
   cardiac properties cited. Infusion 0.5% for stomach pain; 1–1.5% 
   for lumbago and headache. Externally as compress or bath for
   skin/mucosa inflammation and rheumatic pain; wound healing.",
    "evidence_level": "clinical_supported",
    "regions": ["UY", "AR"]
    },
    {
    "use": "Pharmacological data confirm antiinflammatory, antiseptic, antispasmodic, ulcer-protective,
   analgesic, healing, and antipyretic activities from essential
   oil active compounds.",
    "evidence_level": "clinical_supported",
    "regions": ["UY", "AR"]
    }
    ],
    "culinary": ["Herbal infusion", "tea"],
    "aromatic": ["Essential oil used in perfumes, liqueurs,
   shampoos, cosmetics, detergents, lotions, soaps, and alcoholic
   beverages"]
    }
    },
    {
    "plant_id": "sonchus_oleraceus",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used internally: fresh plant
   infusion 1% for liver diseases, promotes bile secretion.
   Concentrated plant juice used as purgative in small doses. Cough
   syrup prepared with whole plant, water, and honey (traditional
   use in Argentina).",
    "evidence_level": "traditional",
    "regions": ["UY", "AR"]
    }
    ],
    "culinary": ["Young leaves and stems cooked as food;
   eaten boiled and seasoned"],
    "aromatic": []
    }
    },
    {
    "plant_id": "taraxacum_officinale",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used: fresh plant juice 50–
   100g/day or decoction 50g/L for skin conditions (depurative and
   diuretic). Prolonged decoction or fresh consumption for 
   pulmonary conditions. Wine decoction of 40g root as febrifuge.
   Leaf infusion 1% for liver conditions.",
    "evidence_level": "traditional",
    "regions": ["UY", "AR"]
    },
    {
    "use": "European sources cite use as choleretic and
   cholagogue for liver conditions; bitter tonic for dyspepsia;
   stomachic for cramps; antirheumatic; and effective diuretic.",
    "evidence_level": "preliminary_science",
    "regions": ["UY"]
    }
    ],
    "culinary": ["Young leaves eaten raw in salad or
   cooked", "Dried root toasted as coffee substitute in
   Argentina"],
    "aromatic": []
    }
    },
    {
    "plant_id": "urtica_urens",
    "categories": {
    "medicinal": [
    {
    "use": "Traditionally used for diuretic, depurative,
   and antihemorrhagic properties. Strong decoctions not
   recommended internally due to circulatory risk. Fresh plant
   juice used for internal hemorrhages. Decoction 20g fresh plant/L
   used as hypoglycemic. Fresh branches applied topically
   (revulsive action) to relieve rheumatic pain. Attributed
   antianemic properties due to mineral content. Powdered leaves
   used as snuff to stop nosebleeds. Occasionally used to stimulate
   hair growth.",
    "evidence_level": "traditional",
    "regions": ["UY", "AR"]
    }
    ],
    "culinary": ["Cooked and eaten as spinach substitute",
   "Commercial source of chlorophyll"],
    "aromatic": []
    }
