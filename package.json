{
  "name": "floralexicon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "dev:reset": "rm -rf .next && WATCHPACK_POLLING=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "validate-country-name-coverage": "tsx scripts/validate-country-name-coverage.ts",
    "ci:coverage": "tsx scripts/validate-country-name-coverage.ts",
    "validate-country-name-coverage:fix": "tsx scripts/validate-country-name-coverage.ts --fix",
    "audit-names": "tsx scripts/audit-names.ts",
    "audit-limited": "tsx scripts/audit-limited-plants.ts",
    "audit-processed-duplicates": "tsx scripts/audit-processed-duplicates.ts",
    "fix-processed-duplicates": "tsx scripts/fix-processed-duplicates.ts",
    "suggest-mappings": "tsx scripts/suggest-name-mappings.ts",
    "canary": "tsx scripts/phase1a-canary.ts",
    "build-from-tier1": "tsx scripts/buildFromTier1.ts",
    "validate-tiers": "python3 scripts/validate_tiers.py",
    "build-dataset": "npm run build-from-tier1 && npm run validate-tiers && npm run canary"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsonrepair": "^3.13.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
